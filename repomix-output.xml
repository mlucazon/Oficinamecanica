            'PI' => ['Piaui', ['Teresina', 'Parnaiba']],
            'RJ' => ['Rio de Janeiro', ['Rio de Janeiro', 'Niteroi', 'Sao Goncalo']],
            'RN' => ['Rio Grande do Norte', ['Natal', 'Mossoro']],
