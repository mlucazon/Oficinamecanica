            margin-bottom: 18px;
        }

        .home-service-strip {
            display: grid;
            grid-template-columns: repeat(4, minmax(0, 1fr));
            gap: 1px;
            margin: -4px 0 18px;
            border: 1px solid rgba(255,255,255,.08);
            border-radius: 12px;
            overflow: hidden;
            background: rgba(255,255,255,.055);
        }

        .home-service-strip > div {
            min-height: 72px;
            display: flex;
            align-items: center;
            gap: 11px;
            padding: 14px 16px;
            background: rgba(10,10,10,.88);
        }

        :root[data-theme="light"] .home-service-strip {
            background: rgba(31,25,20,.10);
            border-color: rgba(31,25,20,.12);
        }

        :root[data-theme="light"] .home-service-strip > div {
            background: rgba(255,255,255,.78);
        }

        .home-service-strip i {
            width: 34px;
            height: 34px;
            border-radius: 50%;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            color: #fff;
            background: linear-gradient(135deg, var(--red), #720000);
            box-shadow: 0 10px 22px rgba(196,0,0,.22);
            flex-shrink: 0;
        }

        .home-service-strip span {
            color: var(--text);
            font-size: 12.5px;
            font-weight: 600;
        }

        .home-location {
            min-height: 520px;
            margin: 18px -1.8rem;
            padding: 86px 5vw;
            display: grid;
            grid-template-columns: minmax(250px, 350px) minmax(520px, 820px);
            align-items: center;
            justify-content: space-between;
            gap: clamp(24px, 4vw, 58px);
            background:
                linear-gradient(90deg, rgba(2,5,12,.92), rgba(2,5,12,.72) 42%, rgba(2,5,12,.30)),
                linear-gradient(0deg, rgba(2,5,12,.86), rgba(2,5,12,.22)),
                url('/img/workshop-hero.jpg');
            background-size: cover;
            background-position: center 55%;
            position: relative;
            overflow: hidden;
        }

        .home-location::before {
            content: '';
            position: absolute;
            left: 6vw;
            top: 118px;
            width: 70px;
            height: 3px;
            background: var(--red);
            transform: translateX(180px);
        }

        .home-location-copy,
        .home-map-card {
            position: relative;
            z-index: 1;
        }

        .home-location h2 {
            font-family: 'Syne', sans-serif;
            font-size: clamp(30px, 3.9vw, 50px);
            line-height: .98;
            font-weight: 800;
            color: #fff;
            margin: 0;
            text-transform: uppercase;
            max-width: 420px;
        }

        .home-location p {
            color: rgba(255,255,255,.78);
            margin: 20px 0 0;
            line-height: 1.55;
            max-width: 410px;
            font-size: 15px;
        }

        .home-location-actions {
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
            margin-top: 26px;
        }

        .home-map-card {
            width: 100%;
            max-width: 680px;
            min-height: 320px;
            justify-self: end;
            border-radius: 14px;
            overflow: hidden;
            border: 1px solid rgba(255,255,255,.16);
            box-shadow: 0 24px 70px rgba(0,0,0,.36);
            background: rgba(255,255,255,.08);
        }

        .home-map-card iframe {
            width: 100%;
            height: 100%;
            min-height: 320px;
            border: 0;
            display: block;
            filter: saturate(.95) contrast(.95);
        }

        :root[data-theme="light"] .home-location {
            background:
                linear-gradient(90deg, rgba(255,255,255,.94), rgba(255,255,255,.72) 42%, rgba(255,255,255,.18)),
                linear-gradient(0deg, rgba(255,255,255,.84), rgba(255,255,255,.18)),
                url('/img/workshop-hero.jpg');
            background-size: cover;
            background-position: center 55%;
        }

        :root[data-theme="light"] .home-location h2 {
            color: #17130f;
        }

        :root[data-theme="light"] .home-location p {
            color: #51483f;
        }

        .location-page {
            min-height: calc(100vh - 3.6rem);
            margin-top: -1.8rem;
            margin-bottom: -1.8rem;
        }

        .stat-money {
            font-size: 21px;
            line-height: 1.15;
        }

        .home-grid {
            display: grid;
            grid-template-columns: minmax(0, 1fr) 340px;
            gap: 18px;
            align-items: start;
        }

        .home-os-card {
            overflow: hidden;
        }

        .home-table td {
            padding-top: 1rem;
            padding-bottom: 1rem;
        }

        .home-plate {
            display: inline-flex;
            margin-top: 3px;
            padding: 2px 7px;
            border: 1px solid var(--border2);
            border-radius: 5px;
            color: var(--text);
            background: rgba(255,255,255,.05);
            font-family: 'DM Mono', monospace;
            font-size: 11px;
        }

        .home-side {
            display: grid;
            gap: 14px;
        }

        .home-flow {
            display: grid;
            gap: 16px;
            position: relative;
        }

        .home-flow::before {
            content: '';
            position: absolute;
            left: 6px;
            top: 10px;
            bottom: 10px;
            width: 1px;
            background: var(--border2);
        }

        .home-flow > div {
            display: grid;
            grid-template-columns: 14px 1fr;
            gap: 12px;
            position: relative;
        }

        .home-flow > div > span {
            width: 13px;
            height: 13px;
            border-radius: 50%;
            background: var(--surface3);
            border: 2px solid var(--border3);
            margin-top: 3px;
            position: relative;
            z-index: 1;
        }

        .home-flow > div.active > span {
            background: var(--red);
            border-color: rgba(255,255,255,.22);
            box-shadow: 0 0 0 5px rgba(196,0,0,.13);
        }

        .home-flow strong {
            display: block;
            color: var(--text);
            font-size: 13px;
        }

        .home-flow small {
            display: block;
            color: var(--text3);
            font-size: 12px;
            margin-top: 2px;
        }

        .home-summary-list,
        .home-part-row + .home-part-row {
            border-top: 1px solid var(--border);
        }

        .home-summary-list {
            display: grid;
        }

        .home-summary-list > div,
        .home-part-row {
            padding: 11px 0;
        }

        .home-summary-list > div:first-child,
        .home-part-row:first-child {
            padding-top: 0;
            border-top: 0;
        }

        .home-summary-list > div:last-child,
        .home-part-row:last-child {
            padding-bottom: 0;
        }

        .home-summary-list span,
        .home-part-row span {
            color: var(--text2);
            font-size: 12.5px;
        }

        .home-summary-list strong,
        .home-part-row strong {
            color: #fff;
            font-family: 'DM Mono', monospace;
            font-size: 13px;
        }

        .btn-primary {
            background: var(--red);
            border-color: var(--red);
            color: #090909;
            font-family: 'DM Sans', sans-serif;
            font-weight: 800;
            transition: all .18s;
            border-radius: 8px;
            padding-left: 1.1rem;
            padding-right: 1.1rem;
        }

        .btn-primary:hover {
            background: #ffca1a;
            border-color: #ffca1a;
            color: #090909;
            box-shadow: 0 10px 28px rgba(196,0,0,.28);
        }

        .btn-outline-primary {
            color: var(--red-h);
            border-color: var(--red-border);
            font-weight: 500;
        }

        .btn-outline-primary:hover {
            background: var(--red-dim);
            border-color: var(--red);
            color: #fff;
        }

        .btn-outline-secondary {
            color: var(--text2);
            border-color: rgba(196,0,0,.72);
            border-radius: 8px;
            font-weight: 700;
        }

        .btn-outline-secondary:hover {
            background: rgba(196,0,0,.12);
            color: #fff;
            border-color: var(--red);
        }

        .btn-outline-danger {
            color: var(--danger-text);
            border-color: rgba(196,0,0,.35);
        }

        .btn-outline-danger:hover {
            background: var(--red-dim);
            border-color: var(--red);
            color: #fff;
        }

        .btn-success {
            background: var(--success);
            border-color: var(--success);
        }

        .btn-warning {
            background: var(--warning);
            border-color: var(--warning);
            color: #000;
        }

        .form-control, .form-select {
            background: var(--surface2);
            border-color: var(--border2);
            color: var(--text);
            font-family: 'DM Sans', sans-serif;
            border-radius: var(--radius-sm);
            transition: border-color .18s, box-shadow .18s;
        }

        .form-control:focus, .form-select:focus {
            background: var(--surface2);
            border-color: var(--red);
            color: var(--text);
            box-shadow: 0 0 0 3px rgba(196,0,0,.15);
        }

        .form-control::placeholder { color: var(--text3); }

        .form-label {
            color: #C0C0C0;
            font-size: .85rem;
            font-weight: 500;
            margin-bottom: .35rem;
        }

        .input-group-text {
            background: var(--surface3);
            border-color: var(--border2);
            color: var(--text3);
        }

        .form-check-input {
            background-color: var(--surface3);
            border-color: var(--border2);
        }

        .form-check-input:checked {
            background-color: var(--red);
            border-color: var(--red);
        }

        .form-text { color: var(--text3); font-size: .8rem; }

        .toast-container {
            position: fixed;
            top: calc(var(--topbar-h) + 16px);
            right: 20px;
            z-index: 9999;
        }

        .toast-at {
            background: var(--surface);
            border: 1px solid var(--border2);
            border-radius: var(--radius);
            box-shadow: 0 8px 32px rgba(0,0,0,.5);
            padding: .75rem 1rem;
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: 13px;
            min-width: 260px;
            animation: slideInRight .28s cubic-bezier(.34,1.56,.64,1);
        }

        .toast-at.toast-success { border-left: 3px solid var(--success-text); }
        .toast-at.toast-error   { border-left: 3px solid var(--red); }

        .toast-at i { font-size: 16px; flex-shrink: 0; }

        .toast-at.toast-success i { color: var(--success-text); }
        .toast-at.toast-error   i { color: var(--danger-text); }

        @keyframes slideInRight {
            from { opacity: 0; transform: translateX(20px); }
            to   { opacity: 1; transform: translateX(0); }
        }

        @keyframes slideOutRight {
            from { opacity: 1; transform: translateX(0); }
            to   { opacity: 0; transform: translateX(20px); }
        }

        .modal-content {
            background: var(--surface);
            border: 1px solid var(--border2);
            border-radius: var(--radius);
            color: var(--text);
            box-shadow: 0 24px 64px rgba(0,0,0,.7);
        }

        .modal-header {
            border-bottom: 1px solid var(--border);
            padding: 1rem 1.2rem;
        }

        .modal-footer {
            border-top: 1px solid var(--border);
            padding: .8rem 1.2rem;
        }

        .modal-title {
            font-family: 'Syne', sans-serif;
            font-weight: 700;
            font-size: 15px;
        }

        .btn-close { filter: invert(1) brightness(.6); }

        .modal-backdrop { background: rgba(0,0,0,.75); }

        .pagination .page-link {
            background: var(--surface2);
            border-color: var(--border);
            color: var(--text2);
            font-size: 12.5px;
            transition: all .15s;
        }

        .pagination .page-link:hover {
            background: var(--surface3);
            border-color: var(--border2);
            color: var(--text);
        }

        .pagination .page-item.active .page-link {
            background: var(--red);
            border-color: var(--red);
            color: #fff;
        }

        .pagination .page-item.disabled .page-link { color: var(--text3); }

        .alert-danger {
            background: var(--danger-bg);
            border-color: var(--red-border);
            color: var(--danger-text);
        }

        .alert-success {
            background: var(--success-bg);
            border-color: rgba(31,122,58,.3);
            color: var(--success-text);
        }

        .alert-warning {
            background: var(--warning-bg);
            border-color: rgba(200,134,10,.3);
            color: var(--warning-text);
        }

        .alert-info {
            background: var(--info-bg);
            border-color: rgba(45,125,210,.3);
            color: var(--info-text);
        }

        a { color: var(--red-h); transition: color .15s; }

        a:hover { color: #ff6666; }

        .text-decoration-none { color: var(--text) !important; }

        .text-decoration-none:hover { color: var(--red-h) !important; }

        .page-header {
            margin-bottom: 1.4rem;
        }

        .page-title {
            font-family: 'Syne', sans-serif;
            font-size: 20px;
            font-weight: 800;
            color: #fff;
            margin: 0 0 2px;
            letter-spacing: -.01em;
        }

        .page-subtitle {
            font-size: 12px;
            color: var(--text3);
        }

        .anim-fade-up {
            opacity: 0;
            transform: translateY(12px);
            animation: fadeUp .4s cubic-bezier(.4,0,.2,1) forwards;
        }

        @keyframes fadeUp {
            to { opacity: 1; transform: translateY(0); }
        }

        #sidebar-overlay {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,.6);
            z-index: 999;
            backdrop-filter: blur(2px);
        }

        @media (max-width: 900px) {
            #sidebar {
                position: relative;
                width: 100%;
                height: auto;
                min-height: 72px;
                flex-wrap: wrap;
                align-items: flex-start;
                padding-bottom: 10px;
                transform: none;
                box-shadow: none;
            }
            #sidebar.open {
                transform: none;
                box-shadow: none;
            }
            .sidebar-brand,
            .sidebar-footer {
                width: 100%;
                height: auto;
                min-height: 68px;
            }
            .nav-scroll {
                width: 100%;
                height: auto;
                overflow: visible;
                flex-wrap: wrap;
                padding: .4rem 1rem;
                flex-direction: row;
            }
            .nav-label { display: none; }
            .nav-link { width: auto; }
            #sidebar-overlay { display: none; }
            #topbar {
                position: sticky;
                left: 0;
                top: 0;
                min-height: auto;
                padding: 10px 1rem;
                flex-wrap: wrap;
            }
            #topbar, #content { margin-left: 0; }
            #content { padding-top: 1rem; }
            .sidebar-toggle { display: flex !important; align-items: center; }
            .home-hero,
            .home-grid {
                grid-template-columns: 1fr;
            }
            .home-metrics {
                grid-template-columns: repeat(2, minmax(0, 1fr));
            }
            .home-service-strip {
                grid-template-columns: repeat(2, minmax(0, 1fr));
            }
            .home-location {
                grid-template-columns: 1fr;
                margin-left: -1rem;
                margin-right: -1rem;
                padding: 60px 24px;
            }
            .home-map-card {
                justify-self: stretch;
                max-width: 100%;
            }
            .home-location::before {
                display: none;
            }
            .home-hero::before {
                right: -28px;
                opacity: .7;
            }
        }

        @media (max-width: 576px) {
            #content { padding: 1rem; }
            .btn-nova-os .btn-text { display: none; }
            .home-hero {
                margin: -1rem -1rem 18px;
                padding: 72px 22px 56px;
                min-height: 640px;
            }
            .home-hero h1 {
                font-size: 36px;
            }
            .home-main-number {
                font-size: 54px;
            }
            .home-metrics {
                grid-template-columns: 1fr;
            }
            .home-service-strip {
                grid-template-columns: 1fr;
            }
            .home-location {
                padding: 52px 22px;
            }
            .home-location h2 {
                font-size: 34px;
            }
            .home-map-card,
            .home-map-card iframe {
                min-height: 280px;
            }
            .home-hero-actions .btn {
                width: 100%;
            }
        }

        @media print {
            #sidebar, #topbar, .no-print { display: none !important; }
            #content { margin: 0; padding: 0; }
            body { background: #fff; color: #000; }
            .card { border: 1px solid #ddd; background: #fff; }
        }
